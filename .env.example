# Copy to .env for local overrides (do not commit .env).
# Vercel: optional — the map build uses defaults unless you customize the asset path.

# Vite `base` (public path). Use "/" on Vercel unless the app is served from a subpath.
# BASE_PATH=/

# Dev server / preview port (local only). Vercel sets its own at runtime; build does not need this.
# PORT=5173

# ── api-server (not used by current Vercel static deploy; only if you run Express locally) ──
# PORT=8080
# LOG_LEVEL=info
# NODE_ENV=production
